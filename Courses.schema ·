{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://learnify.local/schemas/courses.schema.json",
  "title": "Learnify Courses Schema",
  "description": "Schema used to validate the courses JSON file both at creation time (PHP server) and consumption time (jQuery/JS client).",
  "type": "object",
  "required": ["courses", "metadata"],
  "properties": {
    "courses": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["id", "title", "slug", "category", "category_id", "instructor", "level", "price", "rating", "reviews", "description", "tags", "is_published"],
        "properties": {
          "id":             { "type": "integer", "minimum": 1 },
          "title":          { "type": "string",  "minLength": 3, "maxLength": 200 },
          "slug":           { "type": "string",  "pattern": "^[a-z0-9-]+$" },
          "category":       { "type": "string",  "minLength": 2 },
          "category_id":    { "type": "integer", "minimum": 1 },
          "instructor":     { "type": "string",  "minLength": 2 },
          "level": {
            "type": "string",
            "enum": ["beginner", "intermediate", "advanced"]
          },
          "price":          { "type": "number",  "minimum": 0 },
          "rating":         { "type": "number",  "minimum": 0, "maximum": 5 },
          "reviews":        { "type": "integer", "minimum": 0 },
          "thumbnail_icon": { "type": "string" },
          "description":    { "type": "string",  "minLength": 10 },
          "tags": {
            "type": "array",
            "items": { "type": "string" },
            "minItems": 1
          },
          "is_published":   { "type": "boolean" },
          "enrolled_count": { "type": "integer", "minimum": 0 }
        },
        "additionalProperties": false
      }
    },
    "metadata": {
      "type": "object",
      "required": ["total", "version"],
      "properties": {
        "total":        { "type": "integer", "minimum": 0 },
        "version":      { "type": "string" },
        "generated_at": { "type": "string", "format": "date-time" }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
